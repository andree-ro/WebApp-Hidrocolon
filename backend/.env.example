 # Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Railway MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=hidrocolon_user
DB_PASSWORD=your_password_here
DB_NAME=hidrocolon_db
DATABASE_URL=mysql://user:password@host:port/database

# JWT Configuration
JWT_SECRET=tu_super_secreto_jwt_muy_largo_y_seguro_123456789
JWT_EXPIRE=24h

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=*

# Railway Configuration (para producción)
RAILWAY_STATIC_URL=
RAILWAY_PUBLIC_DOMAIN=

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/


